icon = "linkedin"
url = "https://www.linkedin.com/in/khalidra/"

[[params.social]]
name = "Mastodon"
icon = "radio"
url = "https://swecyb.com/@khalid/"

[[params.social]]
name = "email"
icon = "mail"
url = "mailto:khalid-se.br9ty[at]slmail.me"


